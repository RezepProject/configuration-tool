@page "/manage-questions"
@using ConfigurationTool.Model
@using ConfigurationTool.Components
@using ConfigurationTool.Utils
@using Blazored.LocalStorage
@inject ILocalStorageService Localstorage
@inject NavigationManager NavigationManager

@attribute [Authorize]
<!-- TODO: Add roles here like this attribute [Authorize(Roles = "Admin")] -->
@inject IStringLocalizer<ApplicationResource> Localizer

<PageTitle>@Localizer["QuestionsManagement"]</PageTitle>
<MudText Typo="Typo.h3" GutterBottom="true">@Localizer["QuestionsManagement"]</MudText>
<MudGrid>
    <MudItem xs="12" sm="7">
        <MudText Typo="Typo.h5" GutterBottom="true">Add question</MudText>
        <MudPaper Class="pa-4">
            <MudForm @ref="form" @bind-IsValid="@success">
                <MudTextField T="string" Label=@Localizer["Question"] Required="true" @ref="questionInput"
                              RequiredError=@Localizer["ErrorTextQuestion"]
                              Validation="@(new Func<string, IEnumerable<string>>(LengthCheck))"/>

                @foreach (var answer in answers)
                {
                    <MudTextField T="string" Label=@Localizer["Answer"] @ref="answers[answers.IndexOf(answer)]" />
                }

            </MudForm>
        </MudPaper>
        <MudPaper Class="pa-4 mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" DisableElevation="true" OnClick="@AddQuestion">@Localizer["Submit"]</MudButton>
            <MudButton Variant="Variant.Filled" DisableElevation="true" OnClick="@(() => form.Reset())">@Localizer["Reset"]</MudButton>
            <MudButton Variant="Variant.Filled" DisableElevation="true" OnClick="@(() => AddAnswer())">@Localizer["Add Answer"]</MudButton>
        </MudPaper>
    </MudItem>
    
    <MudItem xs="12" sm="7">
        <MudText Typo="Typo.h5" GutterBottom="true">Questions</MudText>
        <MudExpansionPanels>
            @foreach (var question in questions)
            {
                <QuestionListElement Question="@question"/>
            }
        </MudExpansionPanels>
    </MudItem>
</MudGrid>


@code {
    bool success;
    MudTextField<string> questionInput;
    MudForm form;
    List<MudTextField<string>> answers = new() { new MudTextField<string>() };
    List<Question>? questions = new();

    private void AddAnswer()
    {
        if (!answers.Any(a => a.Value == null || string.IsNullOrEmpty(a.Value.Trim())))
        {
            answers.Add(new MudTextField<string>());
            StateHasChanged();
        }
    }

    private async Task AddQuestion()
    {
        var newQuestion = new CreateQuestion()
        {
            Text = questionInput.Value,
            Answers = answers.Where(a => a.Value != null && !string.IsNullOrEmpty(a.Value.Trim())).Select(a =>
                new CreateAnswer { Text = a.Value, User = "NOT IMPLEMENTED"}).ToList()
        };
        
        var res = await HttpUtils.Post<object>("question", newQuestion, await CheckJwt());
        Console.WriteLine(res);
        if (res is string s && s.Contains("Unauthorized"))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        
        form.Reset();
        questions = await GetQuestions(await CheckJwt());
    }
    
    protected override async Task OnInitializedAsync()
    {
        var jwt = await CheckJwt();
        var newQuestions = await GetQuestions(jwt);

        if (newQuestions == null)
        {
            await Localstorage.RemoveItemAsync("token");
            NavigationManager.NavigateTo("/login");
            return;
        }
        questions = newQuestions;
    }
    
    private async Task<List<Question>?> GetQuestions(String jwt)
    {
        return await HttpUtils.Get<List<Question>>("question", jwt);
    }

    private IEnumerable<string> LengthCheck(string input)
    {
        if (string.IsNullOrWhiteSpace(input))
            yield return "Please enter a value";
    }

    async Task<string> CheckJwt()
    {
        var token = await Localstorage.GetItemAsync<string>("token");
        if (token != null) return token;

        await Localstorage.RemoveItemAsync("token");
        NavigationManager.NavigateTo("/login");
        return "";
    }
}