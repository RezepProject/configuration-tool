@namespace ConfigurationTool.Components
@using ConfigurationTool.Model
@using ConfigurationTool.Utils
@using Blazored.LocalStorage
@inject ILocalStorageService Localstorage
@inject NavigationManager NavigationManager

<MudExpansionPanel Text=@Question.Text MaxHeight="500">
    <MudStack>
        <MudItem>Question:</MudItem>
        <MudItem Class="d-flex">
            @if (Question.IsEditing)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Primary" OnClick="@(() => SaveQuestion(Question))"/>
                <MudTextField @bind-Value="@Question.Text"/>
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="@(() => EditQuestion(Question))"/>
                <MudText Style="font-size: 120%; margin-top: 16px">@Question.Text</MudText>
            }
        </MudItem>
        <MudItem>
            Answers:
        </MudItem>
        @foreach (var answer in Question.Answers)
        {
            <MudItem Class="d-flex">
                @if (answer.IsEditing)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Primary" OnClick="@(() => SaveAnswer(answer))"/>
                    <MudTextField @bind-Value="@answer.Text"/>
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="@(() => EditAnswer(answer))"/>
                    <MudText Style="font-size: 120%; margin-top: 16px">@answer.Text</MudText>
                }
            </MudItem>
        }
        <MudItem>
            New Answer:
        </MudItem>
        <MudItem Class="d-flex">
            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"/>
            <MudTextField @bind-Value="NewAnswer"/>
        </MudItem>
    </MudStack>
</MudExpansionPanel>


@code{
    [Parameter] 
    public Question Question { get; set; }

    string NewAnswer { get; set; } = "";

    async Task<string> CheckJwt()
    {
        var token = await Localstorage.GetItemAsync<string>("token");
        if (token != null) return token;

        await Localstorage.RemoveItemAsync("token");
        NavigationManager.NavigateTo("/login");
        return "";
    }

    void EditQuestion(Question? question)
    {
        question.IsEditing = true;
    }

    async void SaveQuestion(Question? question)
    {
        question.IsEditing = false;
        var res = await HttpUtils.Put<object>($"question/{question.Id}", question, await CheckJwt());
        if (res is string s && s.Contains("Unauthorized"))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
    }

    void EditAnswer(Answer answer)
    {
        answer.IsEditing = true;
    }

    async void SaveAnswer(Answer answer)
    {
        answer.IsEditing = false;
        var res = await HttpUtils.Put<object>($"answer/{answer.Id}", answer, await CheckJwt());
        if (res is string s && s.Contains("Unauthorized"))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
    }
    void AddAnswer()
    {
        Question.Answers?.Add(new Answer { Text = NewAnswer });
        NewAnswer = "";
    }
}